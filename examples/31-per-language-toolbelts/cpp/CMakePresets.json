{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "_base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "release",
      "inherits": "_base",
      "displayName": "Release (-O2 with debug info)",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
    },
    {
      "name": "debug",
      "inherits": "_base",
      "displayName": "Debug",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "asan",
      "inherits": "_base",
      "displayName": "ASan + UBSan instrumented build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-O1 -g -fno-omit-frame-pointer -fsanitize=address,undefined",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined"
      }
    },
    {
      "name": "analyze",
      "inherits": "_base",
      "displayName": "GCC static analyzer (-fanalyzer)",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-fanalyzer -O1 -g"
      }
    },
    {
      "name": "release-clang",
      "inherits": "release",
      "displayName": "Release (clang)",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "debug-clang",
      "inherits": "debug",
      "displayName": "Debug (clang)",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    }
  ],
  "buildPresets": [
    { "name": "release",       "configurePreset": "release" },
    { "name": "debug",         "configurePreset": "debug" },
    { "name": "asan",          "configurePreset": "asan" },
    { "name": "analyze",       "configurePreset": "analyze" },
    { "name": "release-clang", "configurePreset": "release-clang" },
    { "name": "debug-clang",   "configurePreset": "debug-clang" }
  ]
}
