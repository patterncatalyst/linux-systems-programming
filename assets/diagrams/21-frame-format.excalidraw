   "updated": 1,
   "link": null,
   "locked": false,
   "text": "Two frame kinds, told apart only by whether text is empty:",
   "fontSize": 12,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "Two frame kinds, told apart only by whether text is empty:",
   "lineHeight": 1.25,
   "baseline": 12
  },
  {
   "id": "t428549704",
   "type": "text",
   "x": 40,
