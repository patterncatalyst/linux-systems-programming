   "isDeleted": false,
   "boundElements": [],
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "JOIN   name  NUL              (empty text)  -- client sends exactly one at connect",
   "fontSize": 11,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "JOIN   name  NUL              (empty text)  -- client sends exactly one at connect",
   "lineHeight": 1.25,
   "baseline": 11
  },
  {
