   "updated": 1,
   "link": null,
   "locked": false,
   "text": "0f 00 00 00  =  0x0000000f  =  15  =  len(\"alice\") + 1 (NUL) + len(\"hello bob\")",
   "fontSize": 12,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "0f 00 00 00  =  0x0000000f  =  15  =  len(\"alice\") + 1 (NUL) + len(\"hello bob\")",
   "lineHeight": 1.25,
   "baseline": 12
  },
  {
   "id": "t1817663814",
