   "versionNonce": 158224597,
   "isDeleted": false,
   "boundElements": [],
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "The ENOMEM is a real, kernel-documented restriction (golang/go#19716): unshare(CLONE_NEWPID) lets the caller create exactly ONE child in the fresh",
   "fontSize": 12,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "The ENOMEM is a real, kernel-documented restriction (golang/go#19716): unshare(CLONE_NEWPID) lets the caller create exactly ONE child in the fresh",
   "lineHeight": 1.25,
   "baseline": 12
  },
  {
   "id": "t1084514099",
   "type": "text",
   "x": 30,
   "y": 562,
   "width": 976.8000000000001,
   "height": 15.0,
   "angle": 0,
   "strokeColor": "#555555",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "strokeWidth": 1,
   "strokeStyle": "solid",
   "roughness": 1,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "roundness": null,
   "seed": 572258032,
   "versionNonce": 859510409,
   "isDeleted": false,
   "boundElements": [],
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "namespace before further forks there return ENOMEM, and os/exec's own vfork/pidfd fast path performs an internal probe fork that silently spends it.",
   "fontSize": 12,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "namespace before further forks there return ENOMEM, and os/exec's own vfork/pidfd fast path performs an internal probe fork that silently spends it.",
   "lineHeight": 1.25,
   "baseline": 12
  }
