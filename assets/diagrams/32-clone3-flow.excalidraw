   "text": "ONE clone(2) creates the child already inside all four namespaces \u2014 no prior unshare(), no LockOSThread needed",
   "fontSize": 14,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "ONE clone(2) creates the child already inside all four namespaces \u2014 no prior unshare(), no LockOSThread needed",
   "lineHeight": 1.25,
   "baseline": 14
  },
